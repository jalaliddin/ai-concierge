# ╔══════════════════════════════════════════════════════════════╗
# ║          Khiva Tour Guide — Docker Environment              ║
# ║   Copy this file and fill in your real values before        ║
# ║   running: docker compose up -d                             ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Laravel Application ──────────────────────────────────────
# Generate with: docker compose run --rm backend php artisan key:generate --show
APP_KEY=base64:CHANGE_ME_RUN_KEY_GENERATE

APP_URL=https://khivatourguide.com
APP_PUBLIC_URL=https://khivatourguide.com
LANDING_URL=https://khivatourguide.com

# ─── Database ─────────────────────────────────────────────────
# Must match MYSQL_ROOT_PASSWORD below
DB_PASSWORD=change_me_strong_password

# ─── AI (Google Gemini) ───────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Telegram Notifications ───────────────────────────────────
# Bot token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890
TELEGRAM_CHAT_ID=-1001234567890

# ─── Mail (for registration card sending) ─────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM_ADDRESS=noreply@khivatourguide.com

# ─── Landing (Nuxt 3) ─────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=https://khivatourguide.com
NUXT_PUBLIC_WHATSAPP=+998935001234
NUXT_PUBLIC_TELEGRAM=@khivatourguide
